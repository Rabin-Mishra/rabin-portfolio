cat > .gitignore << 'EOF'
# Environment variables - CRITICAL: NEVER commit real keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Next.js
.next/
out/
next-env.d.ts

# Dependencies
node_modules/

# Sanity
sanity/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Build artifacts
tsconfig.tsbuildinfo
EOF.env.local
.env.local
.env.local
.env.local
